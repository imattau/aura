{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": [
    "src/demo/**/*",
    "src/shell/**/*",
    "src/nostr/**/*",
    "src/blossom/**/*",
    "src/crypto/**/*",
    "src/cli/**/*"
  ]
}
