{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "WebWorker"],
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": [
    "src/demo/**/*",
    "src/sw/**/*",
    "src/nostr/**/*",
    "src/blossom/**/*",
    "src/crypto/**/*"
  ]
}
